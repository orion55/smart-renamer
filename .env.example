LOG_DIR=./logs
IN_DIR=                    # Входная директория (например f:\Сериалы)

YANDEX_AI_ENABLED=true     # Включить/отключить GPT-агент Yandex AI (true | false)
YANDEX_AI_PROVIDER=agent   # Провайдер: agent (Yandex AI Studio агент) | alice (Alice AI LLM)
YANDEX_API_KEY=            # API-ключ Yandex Cloud
