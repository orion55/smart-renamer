{
  "name": "smart-renamer",
  "version": "1.0.0",
  "description": "CLI utility for automatic renaming and translating of media files",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rimraf dist && ncc build src/index.ts -o dist -m",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "reset-data": "rimraf data && copyfiles -u 1 \"data01/**/*\" data"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ansi-colors": "^4.1.3",
    "cfonts": "^3.3.0",
    "dotenv": "^16.5.0",
    "openai": "^6.34.0",
    "p-limit": "^4.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.2",
    "@vercel/ncc": "^0.38.3",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
